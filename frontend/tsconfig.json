{
	"compilerOptions": {
	  "target": "es2017",
	  "module": "ESNext",
	  "moduleResolution": "Node",
	  "strict": true,
	  "esModuleInterop": true,
	  "resolveJsonModule": true,
	  "allowSyntheticDefaultImports": true,  
	  "outDir": "./public/dist",          
	  "rootDir": "./src",          
	  "baseUrl": "./",            
	  "paths": {
		"*": ["node_modules/*", "src/*"]
	
	  },
	},
	"include": ["src/**/*.ts", "public/**/*.json"],
	"exclude": ["node_modules"]
  }
  