//import sendError from '../plugins/sendError.js'

export default function userRoutes(fastify, options) {
  const db = options.db;

  fastify.get("/hello", (request, reply) => {
    console.log("🧪 reply.sendError =", reply.sendError);
    return reply.sendError(418, "I'm a teapot");
  });

  fastify.get("/hello/:name", (request, reply) => {
    return `Hello ${request.params.name}`;
  });

  fastify.post("/echo", (request, reply) => {
    return { received: request.body.msg };
  });

  fastify.get("/user/:id", {
    preHandler: fastify.checkJWT,
    handler: async (request, reply) => {
      //		const result = await db.get(`SELECT * FROM users WHERE id = ${request.params.id}`);
      // Case id is not a number
      if (isNaN(+request.params.id)) {
        return reply.sendError(400, "Invalid user ID");
      }
      const user = await db.get("SELECT * FROM users WHERE id = ?", [
        request.params.id,
      ]);
      // Case not a user
      if (!user) {
        return reply.sendError(404, `User ${request.params.id} not found`);
      }
      return user;
    },
  });

  fastify.get("/me", {
    preHandler: fastify.checkJWT,
    handler: async (request, reply) => {
      //		const result = await db.get(`SELECT * FROM users WHERE id = ${request.params.id}`);
      // Case id is not a number
      const user = await db.get("SELECT * FROM users WHERE id = ?", [
        request.user.id,
      ]);
      // Case not a user
      if (!user) {
        return reply.sendError(404, `User ${request.params.id} not found`);
      }
      return user;
    },
  });

  fastify.post("/user", async (request, reply) => {
    const { username, email, avatar } = request.body;
    if (!username || !email || !avatar) {
      return reply.code(400).send({
        error: {
          code: 400,
          message: "Missing required fields: username, email or avatar",
        },
      });
    }
    let result;
    try {
      result = await db.run(
        "INSERT INTO users (username, email, avatar) VALUES (?, ?, ?)",
        [username, email, avatar]
      );
    } catch (err) {
      if (err.code === "SQLITE_CONSTRAINT") {
        return reply.code(409).send({
          error: {
            code: 409,
            message: `Username ${request.body.username} already exists`,
          },
        });
      } else {
        return reply.code(500).send({
          error: {
            code: 500,
            message: "Unexpected server error. Please, make an Issue",
          },
        });
      }
    }
    return {
      id: result.lastID,
      username,
      email,
      avatar,
    };
  });

  fastify.get("/protected", {
    preHandler: fastify.checkJWT,
    handler: async (req, reply) => {
      return { message: `Hello ${req.user.username}` };
    },
  });
}
